# PostgreSQL connection URL. Quote the value if it contains & or ?.
# You may use postgresql://… — the app rewrites it to postgresql+psycopg:// (psycopg v3).
# Example:
# DATABASE_URL="postgresql://user:password@host:5432/portfolio"

DATABASE_URL=

# Seconds to wait for TCP connect (default 60). Raises timeout if the host never answers.
# DB_CONNECT_TIMEOUT=60

# AWS RDS from your PC: security group must allow inbound TCP 5432 from your IP (or VPN/bastion).
# Instance must be reachable on the network you use (e.g. "Publicly accessible" + public subnet, or VPN).
# For SSL, append to the URL: ?sslmode=require

# Legacy: if you stored the full URL under this name, the app still picks it up.
# DB_PASSWORD=
